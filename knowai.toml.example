# knowai CLI config.
#
# Two valid spots — pick one (or both, project wins):
#   • ./knowai.toml                          — per-project (walks up from cwd)
#   • ~/.config/knowai/config.toml           — user-global, works everywhere
#
# Precedence (highest first):
#   1. Process env vars already set (CI / Docker overrides win)
#   2. ./knowai.toml in cwd or any parent
#   3. ~/.config/knowai/config.toml
#   4. .env (also read by docker-compose)
#
# Tip: if you commit knowai.toml with real passwords, mark it secret or
# omit `password` here and set POSTGRES_PASSWORD via your shell / secrets.

[database]
host     = "localhost"
port     = 5432
user     = "knowai"
password = "knowai"      # local dev only — use env vars / secrets in prod
db       = "knowai"
schema   = "public"
